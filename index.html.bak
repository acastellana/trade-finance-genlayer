<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FX Settlement Engine — Trade Finance × GenLayer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #ffffff; --card: #f7f7f5; --dark: #1a1817; --muted: #74706c;
      --border: #e5e3e0; --green: #15803d; --green-light: #dcfce7;
      --blue: #1d4ed8; --blue-light: #dbeafe; --amber: #b45309; --amber-light: #fef3c7;
      --red: #dc2626; --red-light: #fee2e2;
      --radius: 10px; --radius-xl: 16px;
      --shadow: 0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.07);
    }
    body { font-family: 'DM Sans', system-ui, sans-serif; background: var(--bg); color: var(--dark); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    .mono { font-family: 'DM Mono', monospace; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* ── HEADER ── */
    header { position: sticky; top: 12px; z-index: 100; padding: 0 24px; }
    .header-inner {
      max-width: 1100px; margin: 0 auto;
      background: rgba(255,255,255,0.95); border: 1px solid var(--border);
      border-radius: 9999px; padding: 10px 20px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: var(--shadow-md); backdrop-filter: blur(12px);
    }
    .logo { display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--dark); font-weight: 700; font-size: 14px; letter-spacing: -0.2px; }
    .logo-chip { background: var(--dark); color: #fff; border-radius: 6px; padding: 2px 8px; font-size: 11px; font-family: 'DM Mono', monospace; font-weight: 500; letter-spacing: 0.3px; }
    nav { display: flex; gap: 2px; }
    nav a { color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 500; padding: 5px 12px; border-radius: 9999px; transition: all 0.15s; }
    nav a:hover { background: var(--card); color: var(--dark); }
    .btn { display: inline-flex; align-items: center; gap: 6px; border: none; border-radius: 9999px; padding: 7px 16px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; text-decoration: none; transition: all 0.15s; }
    .btn-dark { background: var(--dark); color: #fff; }
    .btn-dark:hover { background: #2d2927; }
    .btn-outline { background: #fff; color: var(--dark); border: 1px solid var(--border); }
    .btn-outline:hover { border-color: var(--dark); }

    /* ── HERO ── */
    .hero { padding: 96px 0 72px; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 9999px; padding: 4px 14px;
      font-size: 12px; font-weight: 600; color: var(--muted);
      font-family: 'DM Mono', monospace; margin-bottom: 28px;
    }
    .hero-eyebrow .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: pulse-dot 2s infinite; }
    @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.35} }
    .hero h1 { font-size: clamp(34px, 5vw, 58px); font-weight: 700; line-height: 1.1; letter-spacing: -1.2px; margin-bottom: 20px; max-width: 760px; }
    .hero-sub { font-size: 17px; color: var(--muted); max-width: 540px; line-height: 1.7; margin-bottom: 40px; }
    .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 56px; }
    .hero-stat-row { display: flex; gap: 32px; flex-wrap: wrap; }
    .hero-stat { }
    .hero-stat-val { font-size: 26px; font-weight: 700; letter-spacing: -0.5px; }
    .hero-stat-label { font-size: 12px; color: var(--muted); font-family: 'DM Mono', monospace; }

    /* ── SECTION ── */
    .section { padding: 72px 0; }
    .section-label { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 1.4px; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
    .section-title { font-size: clamp(26px, 3.5vw, 38px); font-weight: 700; letter-spacing: -0.6px; line-height: 1.15; margin-bottom: 14px; }
    .section-sub { font-size: 16px; color: var(--muted); max-width: 520px; line-height: 1.65; }

    /* ── LIVE SETTLEMENT CONSOLE ── */
    .console { background: var(--dark); border-radius: var(--radius-xl); overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.15); }
    .console-bar { background: #242220; padding: 12px 20px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .cdot { width: 11px; height: 11px; border-radius: 50%; }
    .cdot-r { background: #ef4444; } .cdot-y { background: #f59e0b; } .cdot-g { background: #22c55e; }
    .console-title { font-family: 'DM Mono', monospace; font-size: 12px; color: #5a5755; margin-left: 8px; }
    .console-body { padding: 28px 32px; }

    .cl { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-family: 'DM Mono', monospace; font-size: 13px; }
    .cl:last-child { border-bottom: none; }
    .cl-k { color: #5a5755; }
    .cl-v { color: #e5e7eb; }
    .cl-v.green { color: #86efac; }
    .cl-v.amber { color: #fbbf24; }
    .cl-v.blue { color: #93c5fd; }
    .cl-v.muted { color: #5a5755; }
    .cl-v.big { font-size: 18px; font-weight: 500; }
    .console-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 18px 0; }

    .status-rolled { background: rgba(139,92,246,0.15); color: #c4b5fd; border: 1px solid rgba(139,92,246,0.25); padding: 2px 10px; border-radius: 9999px; font-size: 11px; font-weight: 600; letter-spacing: 0.4px; }
    .status-locked { background: rgba(34,197,94,0.12); color: #86efac; border: 1px solid rgba(34,197,94,0.2); padding: 2px 10px; border-radius: 9999px; font-size: 11px; font-weight: 600; letter-spacing: 0.4px; }
    .bench-chip { background: rgba(255,255,255,0.07); color: #9ca3af; padding: 2px 9px; border-radius: 4px; font-size: 11px; }
    .audit-chip { background: rgba(251,191,36,0.1); color: #fbbf24; padding: 2px 9px; border-radius: 4px; font-size: 11px; border: 1px solid rgba(251,191,36,0.15); }

    /* ── BENCHMARK EXPLAINER ── */
    .bench-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media(max-width:680px){ .bench-grid{grid-template-columns:1fr;} }
    .bench-card { border-radius: var(--radius-xl); border: 1px solid var(--border); padding: 28px; }
    .bench-card.live { background: var(--green-light); border-color: rgba(21,128,61,0.2); }
    .bench-card.audit { background: var(--amber-light); border-color: rgba(180,83,9,0.2); }
    .bench-badge { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; padding: 3px 10px; border-radius: 9999px; margin-bottom: 16px; display: inline-block; }
    .bench-badge.live { background: rgba(21,128,61,0.15); color: var(--green); }
    .bench-badge.audit { background: rgba(180,83,9,0.15); color: var(--amber); }
    .bench-card-title { font-size: 19px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.3px; }
    .bench-card-desc { font-size: 14px; color: var(--muted); line-height: 1.65; }
    .bench-card.audit .bench-card-desc { color: #7c5228; }

    /* ── HOW IT WORKS ── */
    .steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    @media(max-width:680px){ .steps{grid-template-columns:1fr;} }
    .step { background: var(--card); border-radius: var(--radius-xl); border: 1px solid var(--border); padding: 26px; }
    .step-num { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); margin-bottom: 16px; font-weight: 600; }
    .step-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .step-title { font-weight: 700; font-size: 16px; margin-bottom: 8px; }
    .step-desc { font-size: 14px; color: var(--muted); line-height: 1.6; }

    /* ── ORACLE FLOW ── */
    .oracle-flow { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 0; align-items: center; }
    @media(max-width:700px){ .oracle-flow{grid-template-columns:1fr; gap:12px;} .oracle-arrow{transform:rotate(90deg); margin:0 auto;} }
    .oracle-node { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-xl); padding: 22px; }
    .oracle-node.gl { background: #1a1817; border-color: #2d2927; color: #e5e7eb; }
    .oracle-arrow { text-align: center; color: var(--muted); padding: 0 8px; font-size: 22px; }
    .oracle-label { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 8px; }
    .oracle-name { font-weight: 700; font-size: 16px; margin-bottom: 6px; }
    .oracle-detail { font-size: 13px; color: var(--muted); line-height: 1.55; }
    .oracle-node.gl .oracle-label { color: #5a5755; }
    .oracle-node.gl .oracle-name { color: #fff; }
    .oracle-node.gl .oracle-detail { color: #9ca3af; }

    /* ── VALIDATOR GRID ── */
    .v-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
    @media(max-width:600px){ .v-grid{grid-template-columns:1fr 1fr;} }
    .v-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 12px; text-align: center; }
    .v-id { font-family: 'DM Mono', monospace; font-size: 11px; color: #5a5755; font-weight: 600; margin-bottom: 6px; }
    .v-rate { font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: #86efac; margin-bottom: 4px; }
    .v-source { font-family: 'DM Mono', monospace; font-size: 10px; color: #5a5755; }
    .v-agree { font-size: 10px; font-weight: 600; margin-top: 6px; }
    .v-agree.agree { color: #86efac; } .v-agree.disagree { color: #f87171; }

    .consensus-display { background: rgba(134,239,172,0.08); border: 1px solid rgba(134,239,172,0.15); border-radius: 10px; padding: 20px 24px; margin-top: 16px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
    .cons-label { font-family: 'DM Mono', monospace; font-size: 11px; color: #5a5755; margin-bottom: 4px; }
    .cons-rate { font-family: 'DM Mono', monospace; font-size: 32px; font-weight: 500; color: #86efac; letter-spacing: -1px; }
    .cons-method { font-family: 'DM Mono', monospace; font-size: 11px; color: #5a5755; margin-top: 4px; }

    /* ── TIMELINE ── */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .tl-row { display: flex; gap: 16px; }
    .tl-line { display: flex; flex-direction: column; align-items: center; }
    .tl-dot { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; }
    .tl-dot-done { background: var(--dark); color: #fff; }
    .tl-dot-green { background: var(--green); color: #fff; }
    .tl-dot-purple { background: #7c3aed; color: #fff; }
    .tl-vline { width: 2px; background: var(--border); flex: 1; min-height: 20px; margin: 4px 0; }
    .tl-body { padding-bottom: 20px; flex: 1; padding-top: 2px; }
    .tl-title { font-weight: 600; font-size: 14px; margin-bottom: 2px; }
    .tl-sub { font-size: 12px; color: var(--muted); }

    /* ── INFO CARDS ── */
    .ic-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; }
    .ic { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
    .ic-label { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 0.3px; text-transform: uppercase; margin-bottom: 6px; }
    .ic-value { font-size: 15px; font-weight: 700; }
    .ic-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

    /* ── MATH BOX ── */
    .math-box { background: var(--dark); border-radius: var(--radius); padding: 20px 24px; }
    .mr { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-family: 'DM Mono', monospace; font-size: 13px; }
    .mr:last-child { border-bottom: none; }
    .mr-k { color: #5a5755; }
    .mr-v { color: #e5e7eb; }
    .mr.total .mr-v { color: #86efac; font-size: 17px; font-weight: 600; }
    .mr.total { padding-top: 12px; }

    /* ── ARCH ── */
    .arch-row { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 16px; }
    .arch-num { width: 28px; height: 28px; border-radius: 50%; background: var(--dark); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .arch-content .arch-title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
    .arch-content .arch-desc { font-size: 14px; color: var(--muted); }

    /* ── CHIPS / TAGS ── */
    .tag { display: inline-flex; align-items: center; gap: 4px; font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 9999px; letter-spacing: 0.2px; }
    .tag-green { background: var(--green-light); color: var(--green); }
    .tag-blue { background: var(--blue-light); color: var(--blue); }
    .tag-amber { background: var(--amber-light); color: var(--amber); }
    .tag-muted { background: var(--card); color: var(--muted); border: 1px solid var(--border); }
    .tag-dark { background: rgba(255,255,255,0.08); color: #9ca3af; }

    /* ── LINK ── */
    .ext-link { display: inline-flex; align-items: center; gap: 4px; font-family: 'DM Mono', monospace; font-size: 11px; color: var(--blue); text-decoration: none; padding: 3px 9px; background: var(--blue-light); border: 1px solid rgba(29,78,216,0.15); border-radius: 6px; }
    .ext-link:hover { text-decoration: underline; }

    /* ── FOOTER ── */
    footer { background: var(--dark); padding: 48px 0 36px; }
    .footer-inner { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 24px; }
    .footer-logo { font-weight: 700; font-size: 14px; color: #fff; display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .footer-note { font-family: 'DM Mono', monospace; font-size: 12px; color: #4b5563; max-width: 360px; line-height: 1.6; }
    .footer-links { display: flex; flex-direction: column; gap: 8px; }
    .footer-links a { color: #4b5563; text-decoration: none; font-size: 13px; transition: color 0.15s; }
    .footer-links a:hover { color: #9ca3af; }
    .footer-bottom { margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.06); font-family: 'DM Mono', monospace; font-size: 11px; color: #3d3b39; }

    /* ── UTILS ── */
    .divider { height: 1px; background: var(--border); margin: 24px 0; }
    @media(max-width:768px){ nav{display:none;} .hero{padding:72px 0 56px;} }
  </style>
</head>
<body>

<!-- ── HEADER ── -->
<header>
  <div class="header-inner">
    <a href="#" class="logo">
      <span class="logo-chip">FX</span>
      Trade Finance
      <span style="color:var(--muted);margin:0 2px">×</span>
      GenLayer
    </a>
    <nav>
      <a href="#settlement">Live Settlement</a>
      <a href="#benchmark">Benchmark</a>
      <a href="#architecture">Architecture</a>
    </nav>
    <a href="#settlement" class="btn btn-dark">View Live Deal →</a>
  </div>
</header>

<!-- ── HERO ── -->
<section class="hero">
  <div class="container">
    <div class="hero-eyebrow">
      <span class="dot"></span>
      Live on Base Sepolia &amp; GenLayer Studionet
    </div>
    <h1>A distributed control plane for cross-border invoice settlement</h1>
    <p class="hero-sub">
      GenLayer coordinates the FX settlement of cross-border invoices by locking a benchmark rate and applying it consistently when payment occurs or settlement dates change.
    </p>
    <div class="hero-actions">
      <a href="#settlement" class="btn btn-dark" style="padding:10px 22px;font-size:14px">View Live Settlement ↓</a>
      <a href="https://sepolia.basescan.org/address/0x5231a9B232abD0d8533D7046994235baEb01696d" target="_blank" class="btn btn-outline" style="padding:10px 22px;font-size:14px">Basescan ↗</a>
    </div>
    <div class="hero-stat-row">
      <div class="hero-stat">
        <div class="hero-stat-val">150,000 BOB</div>
        <div class="hero-stat-label">INVOICE VALUE</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val" style="color:var(--green)">73,950 PEN</div>
        <div class="hero-stat-label">SETTLEMENT LOCKED</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">0.493</div>
        <div class="hero-stat-label">CONSENSUS RATE</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">1</div>
        <div class="hero-stat-label">ROLLS COMPLETED</div>
      </div>
    </div>
  </div>
</section>

<!-- ── WHAT THIS IS NOT ── -->
<section style="padding:0 0 56px">
  <div class="container">
    <div style="border:1px solid var(--border);border-radius:var(--radius-xl);padding:28px 36px;display:flex;align-items:flex-start;gap:48px;flex-wrap:wrap">
      <div style="flex-shrink:0">
        <div style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px">This system is not</div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
          <li style="display:flex;align-items:center;gap:10px;font-size:15px;font-weight:500">
            <span style="width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;color:var(--muted)">✕</span>
            A letter of credit
          </li>
          <li style="display:flex;align-items:center;gap:10px;font-size:15px;font-weight:500">
            <span style="width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;color:var(--muted)">✕</span>
            A bank payment rail
          </li>
          <li style="display:flex;align-items:center;gap:10px;font-size:15px;font-weight:500">
            <span style="width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;color:var(--muted)">✕</span>
            A trade document platform
          </li>
          <li style="display:flex;align-items:center;gap:10px;font-size:15px;font-weight:500">
            <span style="width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;color:var(--muted)">✕</span>
            A cargo dispute resolution system
          </li>
        </ul>
      </div>
      <div style="flex:1;min-width:220px;border-left:1px solid var(--border);padding-left:48px">
        <div style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px">It is</div>
        <p style="font-size:15px;line-height:1.7;color:var(--dark)">
          A coordination layer that locks a benchmark FX rate to a specific invoice, applies that rate when payment occurs, and records a complete audit trail — including any date extensions — on a public chain.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── LIVE SETTLEMENT CONSOLE ── -->
<section id="settlement" class="section" style="background:var(--card)">
  <div class="container">
    <div style="margin-bottom:36px">
      <div class="section-label">Live Settlement</div>
      <div class="section-title">QC-COOP-2026-0001</div>
      <p class="section-sub">
        Bolivian quinoa cooperative → Peruvian food manufacturer.
        Deployed, locked, and rolled on-chain. Zero manual intervention.
      </p>
    </div>

    <div class="console">
      <div class="console-bar">
        <div class="cdot cdot-r"></div>
        <div class="cdot cdot-y"></div>
        <div class="cdot cdot-g"></div>
        <span class="console-title">TradeFxSettlement · Base Sepolia · 0x5231a9B232abD0d8533D7046994235baEb01696d</span>
      </div>
      <div class="console-body">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;flex-wrap:wrap" class="console-main-grid">
          <!-- LEFT: Trade Details -->
          <div>
            <div style="font-family:'DM Mono',monospace;font-size:11px;color:#5a5755;text-transform:uppercase;letter-spacing:1px;margin-bottom:14px">Trade Details</div>
            <div class="cl"><span class="cl-k">status</span><span class="cl-v green"><span class="status-rolled">● ROLLED</span></span></div>
            <div class="cl"><span class="cl-k">invoice_ref</span><span class="cl-v">QC-COOP-2026-0001</span></div>
